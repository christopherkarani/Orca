{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/christopherkarani/Orca/schemas/mcp-manifest-v1.json",
  "title": "Orca MCP Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "server"],
  "properties": {
    "version": { "const": 1 },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "transport"],
      "properties": {
        "name": { "type": "string" },
        "transport": { "enum": ["stdio"] },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_hash": { "type": ["string", "null"] },
        "env": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "default"],
        "properties": {
          "risk": { "enum": ["low", "medium", "high", "critical", "unknown"] },
          "default": { "$ref": "#/$defs/enforcingDecision" }
        }
      }
    },
    "resources": { "$ref": "#/$defs/defaultSection" },
    "prompts": { "$ref": "#/$defs/defaultSection" },
    "sampling": { "$ref": "#/$defs/defaultSection" }
  },
  "$defs": {
    "defaultSection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "$ref": "#/$defs/enforcingDecision" }
      }
    },
    "enforcingDecision": {
      "enum": ["allow", "deny", "ask"]
    }
  }
}
