{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/safety-report-v1.json",
  "title": "Aegis safety report schema v1",
  "description": "Placeholder schema for future customer safety reports. Reports are engineering audit artifacts and are not regulatory approval, certification, airworthiness approval, or real-flight readiness claims.",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_id", "report_version", "vehicle_profile", "adapter_profile", "policy_hash", "scenario_name", "scenario_source", "test_environment", "limitations"],
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "report_version": { "const": 1 },
    "vehicle_profile": { "type": "object" },
    "adapter_profile": { "type": "object" },
    "policy_hash": { "type": "string", "minLength": 1 },
    "scenario_name": { "type": "string", "minLength": 1 },
    "scenario_source": { "type": "string", "minLength": 1 },
    "test_environment": { "enum": ["fake adapter", "PX4 SITL", "ArduPilot SITL", "bench", "other"] },
    "safety_checks_run": { "type": "array", "items": { "type": "string" } },
    "commands_allowed": { "type": "array", "items": { "type": "string" } },
    "commands_denied": { "type": "array", "items": { "type": "string" } },
    "violations_detected": { "type": "array", "items": { "type": "string" } },
    "audit_event_references": { "type": "array", "items": { "type": "string" } },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
