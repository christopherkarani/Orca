{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chriskarani/orca/schemas/policy-v1.json",
  "title": "Orca Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode"],
  "properties": {
    "version": { "const": 1 },
    "mode": { "enum": ["observe", "ask", "strict", "ci", "redteam", "trusted"] },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": { "type": "string" },
        "write_mode": { "enum": ["staged", "direct"] }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inherit": { "type": "boolean" },
        "allow": { "$ref": "#/$defs/stringList" },
        "deny_patterns": { "$ref": "#/$defs/stringList" },
        "ask": { "$ref": "#/$defs/stringList" },
        "default": { "$ref": "#/$defs/decision" }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read": { "$ref": "#/$defs/ruleSet" },
        "write": { "$ref": "#/$defs/fileWriteRuleSet" }
      }
    },
    "commands": { "$ref": "#/$defs/ruleSet" },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["off", "ask", "allowlist", "observe", "open"] },
        "backend": { "enum": ["decision-only", "proxy"] },
        "allow": { "$ref": "#/$defs/stringList" },
        "deny": { "$ref": "#/$defs/stringList" },
        "ask": { "$ref": "#/$defs/stringList" },
        "default": { "$ref": "#/$defs/decision" },
        "detect_exfiltration": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dns": { "type": "boolean" },
            "long_query_strings": { "type": "boolean" },
            "secret_patterns": { "type": "boolean" }
          }
        }
      }
    },
    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_broker": { "type": "string" },
        "brokers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/credentialBroker" }
        },
        "refs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/credentialRef" }
        }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/servicePolicy" }
    },
    "mcp": { "$ref": "#/$defs/mcpPolicy" },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "enum": ["full", "minimal"] },
        "redact_secrets": { "type": "boolean" },
        "tamper_evident": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "decision": { "enum": ["allow", "deny", "ask", "observe"] },
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ruleSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "$ref": "#/$defs/stringList" },
        "deny": { "$ref": "#/$defs/stringList" },
        "ask": { "$ref": "#/$defs/stringList" },
        "default": { "$ref": "#/$defs/decision" }
      }
    },
    "fileWriteRuleSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "$ref": "#/$defs/stringList" },
        "deny": { "$ref": "#/$defs/stringList" },
        "ask": { "$ref": "#/$defs/stringList" },
        "default": { "$ref": "#/$defs/decision" },
        "mode": { "enum": ["staged", "direct"] }
      }
    },
    "servicePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hosts"],
      "properties": {
        "hosts": { "$ref": "#/$defs/stringList" },
        "methods": { "$ref": "#/$defs/stringList" },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": { "$ref": "#/$defs/stringList" },
            "deny": { "$ref": "#/$defs/stringList" }
          }
        },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "use": { "type": "string" }
          }
        },
        "unmatched": { "$ref": "#/$defs/decision" }
      }
    },
    "credentialBroker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["local-dummy", "env-file-dev", "1password-cli", "macos-keychain", "infisical-agent-vault"] },
        "account": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "credentialRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "broker": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "mcpPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "$ref": "#/$defs/stringList" },
        "deny": { "$ref": "#/$defs/stringList" },
        "ask": { "$ref": "#/$defs/stringList" },
        "default": { "$ref": "#/$defs/decision" },
        "servers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tools"],
            "properties": {
              "tools": { "$ref": "#/$defs/ruleSet" }
            }
          }
        }
      }
    }
  }
}
