{
  "SessionStart": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex SessionStart",
          "timeout": 10,
          "statusMessage": "Checking Orca plugin status"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex UserPromptSubmit",
          "timeout": 10,
          "statusMessage": "Checking prompt with Orca"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex PreToolUse",
          "timeout": 15,
          "statusMessage": "Checking tool use with Orca"
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex PermissionRequest",
          "timeout": 15,
          "statusMessage": "Checking permission request with Orca"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex PostToolUse",
          "timeout": 10,
          "statusMessage": "Acknowledging tool use to Orca"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook codex Stop",
          "timeout": 10,
          "statusMessage": "Notifying Orca of session stop"
        }
      ]
    }
  ]
}
