{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orca.local/schemas/hook-request-v1.json",
  "title": "Orca Hook Request v1",
  "description": "JSON payload sent by host plugins to the orca hook command via stdin.",
  "type": "object",
  "required": ["version", "host", "event", "payload"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "Schema version. Must be 1."
    },
    "host": {
      "type": "string",
      "enum": ["codex", "claude", "opencode", "openclaw", "hermes"],
      "description": "Host identifier."
    },
    "event": {
      "type": "string",
      "enum": [
        "SessionStart",
        "UserPromptSubmit",
        "PreToolUse",
        "PermissionRequest",
        "PostToolUse",
        "SessionEnd",
        "Stop",
        "session.created",
        "tool.execute.before",
        "tool.execute.after",
        "permission.asked",
        "permission.replied",
        "file.edited",
        "command.executed",
        "session.updated",
        "session.idle",
        "session.error",
        "shell.env",
        "session.start",
        "tool.before",
        "tool.after",
        "permission.before",
        "permission.after",
        "session.end",
        "on_session_start",
        "pre_tool_call",
        "post_tool_call",
        "pre_llm_call",
        "post_llm_call",
        "on_session_end",
        "on_session_finalize",
        "on_session_reset",
        "subagent_stop"
      ],
      "description": "Host lifecycle event name."
    },
    "payload": {
      "type": "object",
      "description": "Host-specific payload. Shape varies by host and event."
    },
    "session_id": {
      "type": "string",
      "description": "Optional opaque session identifier provided by the host."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the event."
    }
  },
  "additionalProperties": false
}
