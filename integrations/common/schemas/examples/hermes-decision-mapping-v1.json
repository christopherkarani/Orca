{
  "version": 1,
  "host": "hermes",
  "tool_path": {
    "event": "pre_tool_call",
    "ci_hardens_ask_to_block": true,
    "mapping": {
      "allow": { "mode": "proceed" },
      "block": { "mode": "hard_block", "host_action": "block" },
      "ask": {
        "mode": "native_approve_and_resume",
        "host_action": "approve",
        "rule_key": true,
        "notes": "Hermes human gate once/session/always/deny; CI hardens to block"
      },
      "warn": {
        "mode": "advisory_log",
        "notes": "Not collapsed to block"
      },
      "error": { "mode": "fail_closed_block", "host_action": "block" }
    }
  },
  "prompt_path": {
    "event": "pre_llm_call",
    "enforcement": "advisory_context_only",
    "mapping": {
      "allow": { "mode": "proceed" },
      "warn": { "mode": "advisory_context" },
      "context_only": { "mode": "advisory_context" },
      "ask": {
        "mode": "outer_wrapper_required",
        "notes": "Context note must not claim enforcement; prefer orca run -- hermes"
      },
      "block": {
        "mode": "outer_wrapper_required",
        "notes": "Hermes cannot veto pre_llm_call via plugin"
      }
    }
  },
  "limitations": [
    "Hook enforcement is additive; does not replace orca run supervision.",
    "pre_llm_call cannot open approve-and-resume or veto the turn.",
    "Gateway approval UX depends on Hermes platform adapters."
  ]
}
