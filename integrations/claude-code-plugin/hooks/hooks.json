{
  "SessionStart": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude SessionStart",
          "timeout": 10,
          "statusMessage": "Checking Orca plugin status"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude UserPromptSubmit",
          "timeout": 10,
          "statusMessage": "Checking prompt with Orca"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude PreToolUse",
          "timeout": 15,
          "statusMessage": "Checking tool use with Orca"
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude PermissionRequest",
          "timeout": 15,
          "statusMessage": "Checking permission request with Orca"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude PostToolUse",
          "timeout": 10,
          "statusMessage": "Acknowledging tool use to Orca"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "orca hook claude SessionEnd",
          "timeout": 10,
          "statusMessage": "Notifying Orca of session end"
        }
      ]
    }
  ]
}
