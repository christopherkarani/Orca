# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Zig source files
*.zig text eol=lf diff=zig
*.zon text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Web/markup
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary files — do not treat as text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.tar.gz binary
*.tar binary
*.tgz binary
*.gz binary
*.bz2 binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
